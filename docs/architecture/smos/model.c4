// SMOS Architecture — Unified Model
// All elements defined here to avoid FQN conflicts across multi-file merge.

model {
  smos = system 'smos' {
    #rust
    description '''
      Semantic Memory OS — Rust CLI binary for AI agent memory management.
      Hierarchical memory with heat-based eviction, temporal knowledge graph,
      automatic consolidation. One-shot CLI, no daemon.
      '''
    technology 'Rust'

    // L1 Containers
    smos-cli = container 'smos' 'Rust CLI binary (one-shot)' {
      #rust
      description '''
        Single executable. Every call is a separate process:
        open storage → process → close. No daemon.
        Two commands: `context` (read) and `fact` (write).
        Consolidation is built into `smos fact` via threshold-trigger.
        '''
      technology 'Rust'

      context-cmd = component 'context' 'Read command' {
        description '''
          `smos context <topic> [--project] [--from]`
          Embeds topic → searches storage → ranks results → returns JSON.
          '''
      }
      fact-cmd = component 'fact' 'Write command' {
        description '''
          `smos fact <content> [--project] [--agent]`
          Embeds content → extracts entities → writes storage → optional consolidation.
          '''
      }
      consolidation = component 'consolidation' 'Consolidation engine' {
        description '''
          Threshold-triggered, built into `smos fact`. No separate process.
          Steps: dedup → heat update → clustering → summarization (via LLM).
          '''
      }
    }

    storage-container = container 'Storage' 'Embedded datastore' {
      #storage
      description '''
        Opened in-process by smos binary. Three logical areas:
        memories, graph, meta. Location: ~/.smos/<project>/memory.db
        Backend TBD (SQLite/Lance/Surreal). Concurrency via WAL mode.
        '''
      technology 'Embedded DB (TBD)'

      memories = component 'memories' 'Facts store' {
        description 'Facts with embeddings + metadata (project, agent, timestamps, heat, processed-flag)'
      }
      graph = component 'graph' 'Knowledge graph' {
        description 'Entities + edges for multi-hop and temporal validity'
      }
      meta = component 'meta' 'Metadata store' {
        description 'Persona, project configs, consolidation state (threshold counter)'
      }
    }
  }

  ai-agents = actor 'AI Agents' {
    description '''
      opencode runtime agents: head-of-development, architect, engineer,
      tool-accessor, code-quality-reviewer. Interact via bash exec.
      '''
  }

  llm-provider = externalSystem 'LLM Provider' {
    #external
    description '''
      OpenRouter or local Ollama. Used for extraction of facts,
      consolidation (clustering/summarization/dedup), graph-infer.
      '''
    technology 'HTTP API'
  }

  embedding-provider = externalSystem 'Embedding Provider' {
    #external
    description '''
      nomic-embed-text-v2-moe via Ollama. text→vector for semantic search.
      '''
    technology 'HTTP API'
  }

  // === L0 Relationships (high-level) ===
  ai-agents -[sync]-> smos 'bash exec CLI commands, JSON on stdout'
  smos -[sync]-> llm-provider 'HTTP (reqwest), extraction + consolidation prompts'
  smos -[sync]-> embedding-provider 'HTTP (reqwest), text→vector'

  // === L1 Relationships (detailed) ===
  // Agents → CLI
  ai-agents -[sync]-> smos.smos-cli 'bash exec, JSON stdout'

  // CLI context → storage
  smos.smos-cli.context-cmd -[sync]-> smos.storage-container.memories 'read facts (vector + graph)'
  smos.smos-cli.context-cmd -[sync]-> smos.storage-container.graph 'traverse graph paths'

  // CLI fact → storage
  smos.smos-cli.fact-cmd -[sync]-> smos.storage-container.memories 'write fact + embedding'
  smos.smos-cli.fact-cmd -[sync]-> smos.storage-container.graph 'extract entities + edges'

  // CLI consolidation → storage
  smos.smos-cli.consolidation -[sync]-> smos.storage-container.memories 'dedup + heat update'
  smos.smos-cli.consolidation -[sync]-> smos.storage-container.graph 'cluster + update edges'
  smos.smos-cli.consolidation -[sync]-> smos.storage-container.meta 'read/write counter state'

  // CLI → external providers
  smos.smos-cli.context-cmd -[sync]-> embedding-provider 'embed topic for search'
  smos.smos-cli.fact-cmd -[sync]-> embedding-provider 'embed content for storage'
  smos.smos-cli.fact-cmd -[sync]-> llm-provider 'extract entities/relations'
  smos.smos-cli.consolidation -[sync]-> llm-provider 'summarization + clustering'
}
