// SMOS Architecture — Dynamic View: smos fact flow with threshold-triggered consolidation
model {
  // All elements defined in l0 and l1 are merged automatically.
  // This file only adds the dynamic view.
}

views {
  dynamic view factFlow {
    title 'smos fact — Command Flow with Threshold-Triggered Consolidation'
    description '''
      Complete flow of the `smos fact` command:
      1. Parse args (content, --project, --agent)
      2. Embed content → Embedding Provider (HTTP)
      3. Extract entities/relations → LLM Provider (HTTP)
      4. Write to storage (memories + graph edges)
      5. Increment unprocessed counter
      6. Threshold check: counter ≥ N → run consolidation (dedup, heat, cluster, summarize)
      7. Return JSON
      '''

    // Step 1: Parse
    AI Agents -> smos.smosCli 'smos fact <content> [--project] [--agent]'

    // Steps 2-3: Embed + Extract in parallel
    parallel {
      smos.smosCli -> Embedding Provider 'embed content (HTTP)'
      smos.smosCli -> LLM Provider 'extract entities/relations (HTTP)'
    }

    // Step 4: Write to storage
    smos.smosCli -> smos.smosStorage 'write fact + graph edges'

    // Step 5: Increment counter
    smos.smosCli -> smos.smosStorage.meta 'increment unprocessed counter'

    // Step 6: Threshold-triggered consolidation
    smos.smosCli -> smos.smosStorage.meta 'threshold check: counter ≥ N?'

    // Consolidation sub-flow (triggered when threshold met)
    parallel {
      smos.smosCli -> smos.smosStorage 'dedup + heat update'
      smos.smosCli -> LLM Provider 'summarization + clustering (HTTP)'
    }

    smos.smosCli -> smos.smosStorage 'write consolidated results'

    // Step 7: Return JSON
    smos.smosCli <- AI Agents 'JSON: { id, stored, deduped, consolidated }'
  }
}
