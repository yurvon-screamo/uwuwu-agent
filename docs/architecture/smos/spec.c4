specification {
  elementKind system {
    style {
      shape roundedBox
      icon tech:rust
    }
  }

  elementKind actor {
    style {
      shape person
    }
  }

  elementKind container {
    style {
      shape roundedBox
    }
  }

  elementKind component {
    style {
      shape hexagon
    }
  }

  elementKind externalSystem {
    style {
      shape roundedBox
      border dashed
    }
  }

  elementKind datastore {
    style {
      shape cylinder
    }
  }

  relationshipKind sync {
    style {
      line solid
      head arrow
    }
  }

  relationshipKind async {
    style {
      line dashed
      head openArrow
    }
  }

  tag rust {
    icon tech:rust
    color primary
  }

  tag storage {
    color secondary
  }

  tag external {
    color muted
  }
}
