// SMOS Architecture — Level 1: Container View
model {
  smos = system 'smos' {
    description '''
      Semantic Memory OS — Rust CLI binary for AI agent memory management.
      '''
    technology 'Rust'

    smosCli = container 'smos' 'Rust CLI binary (one-shot)' {
      description '''
        Single executable. Every call is a separate process:
        open storage → process → close. No daemon.
        Two commands: `context` (read) and `fact` (write).
        Consolidation is built into `smos fact` via threshold-trigger:
        after writing a fact, if unprocessed counter ≥ N, synchronous
        consolidation runs (dedup + heat update + clustering + summarization via LLM).
        '''
      technology 'Rust'
      tag rust

      commandContext = component 'context' 'Read command' {
        description '''
          `smos context <topic> [--project <name>] [--from <agent>]`
          Embeds topic → searches storage (vector + graph traversal)
          → ranks results → returns JSON { persona, memories[], graph_paths[] }
          '''
      }

      commandFact = component 'fact' 'Write command' {
        description '''
          `smos fact <content> [--project <name>] [--agent <name>]`
          Embeds content → extracts entities/relations → writes storage
          → increments counter → threshold check → optional consolidation
          → returns JSON { id, stored: true, deduped: false, consolidated: true/false }
          '''
      }

      consolidation = component 'consolidation' 'Consolidation engine' {
        description '''
          Threshold-triggered, built into `smos fact`. No separate process/cron.
          Steps: dedup → heat update → clustering → summarization (via LLM).
          '''
      }
    }

    smosStorage = container 'Storage' 'Embedded datastore' {
      description '''
        Opened in-process by smos binary. Three logical areas:
        **memories** — facts with embeddings + metadata (project, agent, timestamps, heat, processed-flag)
        **graph** — entities + edges for multi-hop and temporal validity
        **meta** — persona, project configs, consolidation state (threshold counter)
        '''
      technology 'Embedded DB (TBD: SQLite/Lance/Surreal)'
      location '~/.smos/<project>/memory.db'
      tag storage

      memories = component 'memories' 'Facts store' {
        description 'Facts with embeddings + metadata'
      }

      graph = component 'graph' 'Knowledge graph' {
        description 'Entities + edges for multi-hop and temporal validity'
      }

      meta = component 'meta' 'Metadata store' {
        description 'Persona, project configs, consolidation state'
      }
    }
  }

  AI Agents = actor 'AI Agents' {
    description '''
      opencode runtime agents: head-of-development, architect, engineer,
      tool-accessor, code-quality-reviewer.
      '''
  }

  LLM Provider = externalSystem 'LLM Provider' {
    description '''
      OpenRouter or local Ollama. Used for extraction of facts,
      consolidation (clustering/summarization/dedup), graph-infer.
      '''
    technology 'HTTP API'
    tag external
  }

  Embedding Provider = externalSystem 'Embedding Provider' {
    description '''
      nomic-embed-text-v2-moe via Ollama. text→vector for semantic search.
      '''
    technology 'HTTP API'
    tag external
  }

  // External relationships — agents to smos
  AI Agents -[sync]-> smos.smosCli 'bash exec, JSON stdout'

  // Internal relationships — smos CLI to storage
  smos.smosCli.commandContext -[sync]-> smos.smosStorage.memories 'read facts (vector + graph)'
  smos.smosCli.commandContext -[sync]-> smos.smosStorage.graph 'traverse graph paths'
  smos.smosCli.commandFact -[sync]-> smos.smosStorage.memories 'write fact + embedding'
  smos.smosCli.commandFact -[sync]-> smos.smosStorage.graph 'extract entities + edges'
  smos.smosCli.consolidation -[sync]-> smos.smosStorage.memories 'dedup + heat update'
  smos.smosCli.consolidation -[sync]-> smos.smosStorage.graph 'cluster + update edges'
  smos.smosCli.consolidation -[sync]-> smos.smosStorage.meta 'read/write counter state'

  // External relationships — smos to providers
  smos.smosCli.commandContext -[sync]-> Embedding Provider 'embed topic for search'
  smos.smosCli.commandFact -[sync]-> Embedding Provider 'embed content for storage'
  smos.smosCli.commandFact -[sync]-> LLM Provider 'extract entities/relations'
  smos.smosCli.consolidation -[sync]-> LLM Provider 'summarization + clustering'
}

views {
  view l1 of smos {
    title 'SMOS — Container View (L1)'
    description '''
      Container-level view: smos CLI binary (one-shot, 2 commands + consolidation engine),
      embedded storage (3 logical areas), and external HTTP providers (LLM + Embedding).
      '''
    include smos.**
    include -> smos
    include smos.smosCli -> LLM Provider
    include smos.smosCli -> Embedding Provider

    style smos.smosCli {
      color primary
      icon tech:rust
    }
    style smos.smosStorage {
      color secondary
      icon tech:sqlite
    }
    style AI Agents {
      color primary
    }
    style LLM Provider {
      color muted
    }
    style Embedding Provider {
      color muted
    }
  }
}
