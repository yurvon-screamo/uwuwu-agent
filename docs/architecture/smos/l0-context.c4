// SMOS Architecture — Level 0: System Context
model {
  smos = system 'smos' {
    description '''
      Semantic Memory OS — Rust CLI binary for AI agent memory management.
      Hierarchical memory with heat-based eviction, temporal knowledge graph,
      automatic consolidation. One-shot CLI, no daemon.
      '''
    technology 'Rust'
    tag rust
  }

  AI Agents = actor 'AI Agents' {
    description '''
      opencode runtime agents: head-of-development, architect, engineer,
      tool-accessor, code-quality-reviewer.
      '''
  }

  LLM Provider = externalSystem 'LLM Provider' {
    description '''
      OpenRouter or local Ollama. Used for extraction of facts,
      consolidation (clustering/summarization/dedup), graph-infer.
      '''
    technology 'HTTP API'
    tag external
  }

  Embedding Provider = externalSystem 'Embedding Provider' {
    description '''
      nomic-embed-text-v2-moe via Ollama. text→vector for semantic search.
      '''
    technology 'HTTP API'
    tag external
  }

  Storage = datastore 'Storage' {
    description '''
      Embedded, local at ~/.smos/<project>/. Not a separate process.
      Three logical areas: memories, graph, meta.
      '''
    location '~/.smos/<project>/memory.db'
    tag storage
  }

  // Relationships
  AI Agents -[sync]-> smos 'bash exec CLI commands, JSON on stdout'
  smos -[sync]-> LLM Provider 'HTTP (reqwest), extraction + consolidation prompts'
  smos -[sync]-> Embedding Provider 'HTTP (reqwest), text→vector'
  smos -[sync]-> Storage 'in-process embedded access (WAL mode)'
}

views {
  view l0 of smos {
    title 'SMOS — System Context (L0)'
    description '''
      High-level view showing smos at the center, AI agents as direct consumers,
      LLM and Embedding providers as external HTTP dependencies, and embedded storage.
      '''
    include *
    include -> smos
    include smos ->

    style smos {
      color primary
      icon tech:rust
    }
    style AI Agents {
      color primary
    }
    style LLM Provider {
      color muted
    }
    style Embedding Provider {
      color muted
    }
    style Storage {
      color secondary
      icon tech:sqlite
    }
  }
}
