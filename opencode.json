{
    "$schema": "https://opencode.ai/config.json",
    "default_agent": "head-of-development",
    "command": {
        "remember": {
            "template": "Надо что то запомнить (сохранить в память)? Или такого нет?",
            "description": "запоминаем важное"
        }
    },
    "mcp": {},
    "permission": {
        "skill": {
            "flow-*": "deny",
            "tool-*": "deny",
            "engineer-*": "deny",
            "office-coworker-*": "deny",
            "rules-*": "allow",
            "tool-generic-*": "allow"
        },
        "task": {
            "*": "deny"
        }
    },
    "tools": {
        "memory_*": true,
        "time_*": true
    },
    "plugin": ["@warp-dot-dev/opencode-warp"]
}
