# @marketer agent credentials template.
# Copy this file to `.env` and fill in real values. The `.env` file is gitignored
# and read ONLY by @tool-accessor through tool-integration-* skills.
#
# @marketer has NO direct access to these values (no bash in frontmatter).
# Credential isolation is enforced architecturally, not just by convention.

# Reddit (PRAW OAuth script-app, read-only monitoring).
# https://www.reddit.com/prefs/apps — create "script" app.
# UA format (Reddit requirement): <platform>:<app_id>:<version> (by /u/<username>)
#
# NOTE: REDDIT_USER_AGENT and REDDIT_USERNAME are pre-filled below because they
# are PUBLIC identifiers (not secrets). UA format is a Reddit hard-requirement
# and must not be blank; the username is publicly visible on every Reddit post.
# All actual secrets (CLIENT_SECRET, PASSWORD) stay empty.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=windows:uwuwu-marketer-monitor:v1.0.0 (by /u/turbin_y)
REDDIT_USERNAME=turbin_y
# REDDIT_PASSWORD is OPTIONAL: only needed for user-private scopes (e.g., reading
# turbin_y's own submission history). For pure read-only subreddit monitoring,
# leave it empty and use application-only OAuth (see tool-integration-reddit skill).
REDDIT_PASSWORD=

# dev.to (Forem API key).
# https://dev.to/settings/extensions — "DEV Community API Keys".
DEVTO_API_KEY=

# Product Hunt (GraphQL v2 — OAuth2 Developer Token).
# https://www.producthunt.com/v2/oauth/applications — create app, issue Developer Token.
# NOTE: API is READ-ONLY for third parties. Submit/comment/vote = browser via Playwright.
PH_API_TOKEN=
PH_CLIENT_ID=
PH_CLIENT_SECRET=

# NOTE: Hashnode removed from MVP (Pro required since May 2026). Re-add in Phase 4 if needed.
# NOTE: X/Twitter = read-only + manual publication ($100/mo Basic is too expensive for MVP).
# NOTE: LinkedIn = skipped (ToS risk for turbin_y account, deferred to B2B Phase).
