        { "type": "reasoning", "text": "Checking the auth implementation in auth.rs before answering." },
        { "type": "text", "text": "Project Aurora uses JWT for authentication with a TTL of 10 minutes to prevent infinite refresh loops. The validate_token function in auth.rs handles signature verification and rejects any token whose signature does not match the server secret." }
      ]
